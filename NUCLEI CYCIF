import cv2
import numpy as np
import torch
from pathlib import Path
from cellpose import models
from skimage.segmentation import watershed
from skimage.feature import peak_local_max
from scipy import ndimage







file_path = Path(
    r"C:\Users\umyed\OneDrive\Desktop\Ramanathan Lab\Tumor Grade Files\New Tumor Grade Files (6-27-26)\results\Normal Grade 1 CYCIF_cytoplasm_QC.png"
)




output_dir = file_path.parent
base_name = file_path.stem






img = cv2.imread(
    str(file_path),
    cv2.IMREAD_UNCHANGED
)


print("Image shape:", img.shape)




# Remove alpha channel
if len(img.shape) == 3 and img.shape[2] == 4:
    img = img[:, :, :3]




# Convert to grayscale
if len(img.shape) == 3:
    gray = cv2.cvtColor(
        img,
        cv2.COLOR_BGR2GRAY
    )
else:
    gray = img




# Normalize
gray = cv2.normalize(
    gray,
    None,
    0,
    255,
    cv2.NORM_MINMAX
).astype(np.uint8)








use_gpu = torch.cuda.is_available()


print("GPU:", use_gpu)


model = models.CellposeModel(
    gpu=use_gpu
)




print("Running nucleus segmentation...")




masks, flows, styles = model.eval(
    gray,
    diameter=25,
    flow_threshold=0.6,
    cellprob_threshold=0.2
)




print(
    "Raw nuclei:",
    len(np.unique(masks))-1
)








binary = masks > 0




distance = ndimage.distance_transform_edt(binary)


coords = peak_local_max(
    distance,
    min_distance=8,


    labels=binary
)




markers = np.zeros(
    distance.shape,
    dtype=int
)




for i, coord in enumerate(coords):
    markers[tuple(coord)] = i + 1




split_masks = watershed(
    -distance,
    markers,
    mask=binary
)








final_masks = np.zeros_like(split_masks)


new_id = 1




for nid in np.unique(split_masks):


    if nid == 0:
        continue


    area = np.sum(split_masks == nid)




    # realistic nucleus size for small crop
    if 30 <= area <= 500:


        final_masks[
            split_masks == nid
        ] = new_id


        new_id += 1






nuc_masks = final_masks




print(
    "Final nuclei:",
    len(np.unique(nuc_masks))-1
)








np.save(
    output_dir / f"{base_name}_nuc_masks.npy",
    nuc_masks
)









binary_out = (
    nuc_masks > 0
).astype(np.uint8)*255




cv2.imwrite(
    str(output_dir / f"{base_name}_nuc_binary.png"),
    binary_out
)









label_img = np.zeros(
    (
        nuc_masks.shape[0],
        nuc_masks.shape[1],
        3
    ),
    dtype=np.uint8
)




rng = np.random.default_rng(5)




for nid in np.unique(nuc_masks):


    if nid == 0:
        continue


    label_img[
        nuc_masks == nid
    ] = rng.integers(
        50,
        255,
        3
    )




cv2.imwrite(
    str(output_dir / f"{base_name}_nuc_labels.png"),
    label_img
)




print("\nSaved:")
print("nuc_masks.npy")
print("nuc_binary.png")
print("nuc_labels.png")
print("\nDone.")

